{
  "multipart": [
	{
      "when": {"north": "true"},
      "apply": [
		{ "model": "genesis:block/salt_vine", "x": 90, "y": 180 }
	  ]
    },
    {
      "when": { "east": "true" },
      "apply": [
		{ "model": "genesis:block/salt_vine", "x": 90, "y": 270 }
	  ]
    },
    {
      "when": { "south": "true" },
      "apply": [
		{ "model": "genesis:block/salt_vine", "x": 90 }
	  ]
    },
    {
      "when": { "west": "true" },
      "apply": [
		{ "model": "genesis:block/salt_vine", "x": 90, "y": 90 }
	  ]
    },
    {
      "when": { "up": "true" },
      "apply": [
		{ "model": "genesis:block/salt_vine", "x": 180 }
	  ]
    },
    {
      "when": { "down": "true" },
      "apply": [
		{ "model": "genesis:block/salt_vine" }
	]
    }
  ]
}